# .env.example for protected.core.trade
# 
# This repo is the core package. The actual .env/config is provided by the
# delivery container (trade repo) or injected by the SaaS worker.
# 
# Copy relevant sections to your delivery .env or config.json.
# Fill real values at the end. Never commit secrets.

# =============================================================================
# Exchange Credentials (required for live trading)
# =============================================================================
EXCHANGE__KEY=your_binance_or_other_api_key
EXCHANGE__SECRET=your_exchange_api_secret

# =============================================================================
# Telegram (for engine internal / commands if enabled)
# =============================================================================
TELEGRAM__TOKEN=your_telegram_bot_token
TELEGRAM__CHAT_ID=your_chat_id

# =============================================================================
# Honeytrade SaaS / Risk Overrides (in config.json or env)
# =============================================================================
HONEYTRADE_PROFILE=balanced
HONEYTRADE__RISK__BASE_POSITION_SIZE=35.0
HONEYTRADE__RISK__CAPITAL_GROWTH_FRACTION=0.05
# ... add other risk params as needed

# =============================================================================
# SaaS Telemetry (injected by worker for sorunsuz pods - critical)
# =============================================================================
HONEYTRADE_TELEMETRY_INGEST_URL=https://your-supabase-ref.supabase.co/functions/v1/ingest-telemetry
HONEYTRADE_INGEST_TOKEN=per_instance_bearer_token_from_worker
HONEYTRADE_ORGANIZATION_ID=org_uuid_from_postcheckout
HONEYTRADE_INSTANCE_ID=instance_uuid
HONEYTRADE_CORRELATION_ID=sorunsuz-...

# =============================================================================
# License
# =============================================================================
HONEYTRADE__LICENSE_KEY=CRYPTO-your-license-key
HONEYTRADE__LICENSE_MACHINE_ID=your_machine_id_hash

# See trade repo telemetry/ for full integration and patch.
